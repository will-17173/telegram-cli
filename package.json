{
  "name": "@will-17173/telegram-cli",
  "version": "0.6.1",
  "type": "module",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/will-17173/telegram-cli.git"
  },
  "homepage": "https://will-17173.github.io/telegram-cli/",
  "bugs": {
    "url": "https://github.com/will-17173/telegram-cli/issues"
  },
  "bin": {
    "tg": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:web": "vite build --config web/vite.config.ts",
    "build": "pnpm clean && pnpm build:web && tsc -p tsconfig.build.json",
    "dev": "tsx src/dev.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p web/tsconfig.json",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm test && pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@mtcute/node": "^0.31.0",
    "better-sqlite3": "^12.10.0",
    "commander": "^14.0.2",
    "ink": "^6.5.1",
    "jpeg-js": "^0.4.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.7",
    "string-width": "^8.2.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.2.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.0.18"
  }
}
